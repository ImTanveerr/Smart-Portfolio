// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model Post {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tags        Tag[]     @relation("PostTags")
}

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  summary     String
  description String
  coverImage  String?
  repoUrl     String?
  liveUrl     String?
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  techStack   Tag[]    @relation("ProjectTech")
}

model Profile {
  id            String   @id @default("profile")
  name          String?
  title         String?
  description   String?
  aboutContent  String?
  email         String?
  phone         String?
  avatarImage   String?
  avatarImage2  String?
  githubUrl     String?
  linkedinUrl   String?
  twitterUrl    String?
  websiteUrl    String?
  resumeUrl     String?
  projectsCount Int      @default(3)
  postsCount    Int      @default(3)
  updatedAt     DateTime @updatedAt
}

model Tag {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  posts    Post[]    @relation("PostTags")
  projects Project[] @relation("ProjectTech")
}

enum SkillCategory {
  FRONTEND
  BACKEND
  DEVOPS
  OTHER
}

model Skill {
  id        String        @id @default(cuid())
  name      String        @unique
  category  SkillCategory
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskRecurrence {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

// Backs both the admin todo list and the admin calendar - they're the same
// underlying tasks, just two views of them. The todo list shows everything,
// smart-sorted by urgency; the calendar shows only tasks that have a
// dueDate, grouped by day. Giving a todo a due date is what puts it on the
// calendar, rather than these being two separate item types.
//
// Recurring tasks are materialized as individual rows sharing a `seriesId`
// (see src/lib/recurrence.ts) rather than computed on the fly, so each
// occurrence can be completed, edited, or deleted independently.
model Task {
  id         String         @id @default(cuid())
  title      String
  notes      String?
  done       Boolean        @default(false)
  priority   TaskPriority   @default(MEDIUM)
  dueDate    DateTime?
  startTime  String? // "HH:mm", 24h
  endTime    String? // "HH:mm", 24h
  recurrence TaskRecurrence @default(NONE)
  seriesId   String?
  tags       String[]       @default([])
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([dueDate])
  @@index([seriesId])
}

// A project inquiry submitted through the public /contact page. Writable by
// anonymous visitors (no requireAdmin() on the action that creates these),
// which is what makes this model different from everything else here.
model ContactMessage {
  id          String   @id @default(cuid())
  name        String
  email       String
  projectType String?
  budget      String?
  message     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([read])
}
